{
  "name": "@cragjs/indexing",
  "version": "0.1.0",
  "description": "Módulo de indexação e busca semântica para CodeRAG - Suporta embeddings locais (Ollama) e bancos vetoriais",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "postinstall": "ts-node scripts/download-model.ts",
    "download-model": "ts-node scripts/download-model.ts",
    "test:index": "tsx test-indexing-local.ts"
  },
  "keywords": [
    "code-indexing",
    "semantic-search",
    "embeddings",
    "ollama",
    "vector-database",
    "rag",
    "code-analysis"
  ],
  "author": "juliumnix",
  "license": "MIT",
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@huggingface/hub": "^2.6.13",
    "@pinecone-database/pinecone": "^6.1.3",
    "node-llama-cpp": "^3.14.2",
    "ollama": "^0.6.2",
    "pino": "^9.0.0",
    "tree-sitter": "^0.21.0",
    "tree-sitter-typescript": "^0.23.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.6.0"
  }
}
